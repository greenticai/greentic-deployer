{
  "type": "object",
  "required": [
    "kind",
    "capability",
    "provider",
    "strategy",
    "terraform_root",
    "generated_files",
    "supported_clouds",
    "cloud_modules"
  ],
  "properties": {
    "kind": { "const": "generate" },
    "capability": { "const": "generate" },
    "provider": { "const": "generic" },
    "strategy": { "const": "terraform" },
    "terraform_root": { "const": "terraform" },
    "supported_clouds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["aws", "azure", "gcp"]
      },
      "minItems": 3
    },
    "cloud_modules": {
      "type": "object",
      "required": ["aws", "azure", "gcp"],
      "properties": {
        "aws": { "type": "string" },
        "azure": { "type": "string" },
        "gcp": { "type": "string" }
      },
      "additionalProperties": false
    },
    "generated_files": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "main.tf" },
      "minItems": 11
    }
  }
}
