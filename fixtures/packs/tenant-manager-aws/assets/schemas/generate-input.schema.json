{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TenantManagerAwsDeployInput",
  "type": "object",
  "required": ["aws_region", "image_uri", "domain_name", "acm_certificate_arn",
               "vpc_id", "subnet_ids", "master_key_secret_arn", "platform_secret_hash_arn"],
  "properties": {
    "aws_region": { "type": "string" },
    "image_uri": { "type": "string", "description": "digest-pinned tenant-manager image" },
    "db_instance_class": { "type": "string", "default": "db.t4g.micro" },
    "domain_name": { "type": "string" },
    "acm_certificate_arn": { "type": "string" },
    "vpc_id": { "type": "string" },
    "subnet_ids": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
    "master_key_secret_arn": { "type": "string" },
    "platform_secret_hash_arn": { "type": "string" },
    "database_url_secret_arn": { "type": "string", "description": "Secrets Manager ARN of the full libpq TENANT_DATABASE_URL (incl. ?sslmode=require). When set, external Postgres is used and no RDS is provisioned." },
    "existing_https_listener_arn": { "type": "string", "description": "Shared ALB HTTPS listener ARN to attach a host-based rule to (reuse instead of creating a dedicated ALB)." },
    "existing_alb_security_group_id": { "type": "string", "description": "Security group of the shared ALB; required when existing_https_listener_arn is set." },
    "listener_rule_priority": { "type": "integer", "default": 100 },
    "desired_count": { "type": "integer", "default": 1, "description": "Initial ECS desired count; 0 for scale-to-zero." },
    "min_capacity": { "type": "integer", "default": 1 },
    "max_capacity": { "type": "integer", "default": 1 },
    "environment": { "type": "string", "default": "prod" },
    "name_prefix": { "type": "string", "default": "greentic-tm" },
    "create_dns_record": { "type": "boolean", "default": true }
  }
}
