{
  "kind": "plan",
  "capability": "plan",
  "provider": "azure",
  "strategy": "terraform",
  "terraform_init_command": "terraform init -backend-config=backend.hcl",
  "terraform_plan_command": "terraform plan -var-file=staging.tfvars.example",
  "expected_variables": [
    "image_uri",
    "azure_subscription_id",
    "azure_resource_group",
    "azure_location",
    "domain_name",
    "key_vault_id",
    "master_key_secret_id",
    "platform_secret_hash_secret_id"
  ]
}
