{
  "type": "object",
  "required": [
    "environment",
    "operator_image_digest",
    "bundle_source",
    "bundle_digest",
    "gcp_project_id",
    "gcp_region",
    "remote_state_backend"
  ],
  "properties": {
    "environment": { "type": "string", "minLength": 1 },
    "operator_image_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "dns_name": { "type": "string" },
    "bundle_source": { "type": "string", "minLength": 1 },
    "bundle_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "redis_url": { "type": "string", "minLength": 1 },
    "repo_registry_base": { "type": "string" },
    "store_registry_base": { "type": "string" },
    "admin_allowed_clients": { "type": "string" },
    "gcp_project_id": { "type": "string", "minLength": 1 },
    "gcp_region": { "type": "string", "minLength": 1 },
    "public_base_url": { "type": "string", "minLength": 1 },
    "remote_state_backend": { "type": "string", "minLength": 1 }
  }
}
