{
  "type": "object",
  "required": [
    "kind",
    "capability",
    "provider",
    "strategy",
    "startup_contract",
    "environment_variables",
    "required_secrets"
  ],
  "properties": {
    "kind": { "const": "plan" },
    "capability": { "const": "plan" },
    "provider": { "const": "generic" },
    "strategy": { "const": "serverless-container" },
    "startup_contract": { "type": "string", "minLength": 1 },
    "environment_variables": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "REDIS_URL" }
    },
    "required_secrets": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

