{
  "schema": "greentic.env-manifest.v1",
  "environment": {
    "id": "@@ENV_ID@@",
    "name": "cloudrun-demo"
  },
  "trust_root": "bootstrap",
  "packs": [
    {
      "slot": "deployer",
      "kind": "greentic.deployer.gcp-cloudrun@1.0.0",
      "pack_ref": "builtin",
      "answers": {
        "project": "@@PROJECT@@",
        "region": "@@REGION@@",
        "access_mode": "@@ACCESS_MODE@@",
        "runtime_image_digest": "@@IMAGE_DIGEST@@"
      }
    },
    {
      "slot": "secrets",
      "kind": "greentic.secrets.dev-store@1.0.0",
      "pack_ref": "builtin"
    }
  ],
  "bundles": [
    {
      "bundle_id": "cloudrun-demo",
      "bundle_source_uri": "@@BUNDLE_URI@@",
      "bundle_digest": "@@BUNDLE_DIGEST@@",
      "route_binding": {
        "path_prefixes": ["/"]
      }
    }
  ]
}
