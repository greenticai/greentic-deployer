      "adapter": "snap",
      "mode": "execute",
      "environment": "snap-vm",
      "steps": ["generate", "apply", "status", "destroy"]
    },
    {
      "tier": 3,
      "adapter": "juju-machine",
      "mode": "handoff",
      "environment": "juju-machine-controller",
      "steps": ["generate", "plan", "status"]
